---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

type Props = {
  work: CollectionEntry<'works'>;
};

const { work } = Astro.props;
const { title, thumbnail, summary, slug } = work.data;
---

<a href={`/works/${slug}`} class="card">
  <div class="thumb">
    <Image src={thumbnail} alt={title} widths={[400, 800]} sizes="(max-width: 768px) 100vw, 33vw" />
  </div>
  <div class="meta">
    <h3>{title}</h3>
    <p>{summary}</p>
  </div>
</a>

<style>
  .card {
    display: block;
    color: inherit;
  }

  .card:hover {
    text-decoration: none;
  }

  .thumb {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--color-border);
  }

  .thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease-out);
  }

  .card:hover .thumb :global(img) {
    transform: scale(1.03);
  }

  .meta {
    margin-top: var(--space-2);
  }

  .meta h3 {
    font-size: var(--text-base);
    margin-bottom: 4px;
  }

  .meta p {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
</style>
